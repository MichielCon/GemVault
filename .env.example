# Connection string for the API
ConnectionStrings__DefaultConnection=Host=db;Port=5432;Database=gemvault;Username=gemvault;Password=changeme_dev

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme_dev
